<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>

            <link rel="shortcut icon" href="{{ asset('assets/images/logo/favicon.png') }}">
            <link rel="stylesheet" href="{{ asset('assets/css/bootstrap.min.css') }}">
            <link rel="stylesheet" href="{{ asset('assets/css/fontawesome-all.min.css') }}">
            <link rel="stylesheet" href="{{ asset('assets/css/magnific-popup.css.css') }}">
            <link rel="stylesheet" href="{{ asset('assets/css/slick.css') }}">
            <link rel="stylesheet" href="{{ asset('assets/css/line-awesome.min.css') }}">
            <link rel="stylesheet" href="{{ asset('assets/css/image-uploader.min.css') }}">
            <link rel="stylesheet" href="{{ asset('assets/css/jquery-ui.css') }}">
            <link rel="stylesheet" href="{{ asset('assets/css/main.css') }}">          
    </head>
    <body>
        <div class="preloader">
            <div class="loader"></div>
        </div>
        <div class="overlay"></div>
        <div class="side-overlay"></div>
        <div class="progress-wrap">
            <svg class="progress-circle svg-content" width="100%" height="100%" viewBox="-1 -1 102 102">
                <path d="M50,1 a49,49 0 0,1 0,98 a49,49 0 0,1 0,-98" />
            </svg>
        </div>
        {% include '_partials/header.html.twig' %}
        {% include '_partials/canvas.html.twig' %}

        <main class="body-bg">
            {% include '_partials/header-top.html.twig' %}
            {% include '_partials/menu.html.twig' %}

            {% block body %}{% endblock %}
        </main>


            <script src="{{ asset('assets/js/jquery-3.7.1.min.js') }}"></script>
            <script src="{{ asset('assets/js/boostrap.bundle.min.js') }}"></script>
            <script src="{{ asset('assets/js/magnific-popup.min.js') }}"></script>
            <script src="{{ asset('assets/js/slick.min.js') }}"></script>
            <script src="{{ asset('assets/js/counterup.min.js') }}"></script>
            <script src="{{ asset('assets/js/jquery.marquee.min.js') }}"></script>
            <script src="{{ asset('assets/js/image-uploader.min.js') }}"></script>
            <script src="{{ asset('assets/js/jquery-ui.min.js') }}"></script>
            <script src="{{ asset('assets/js/main.js') }}"></script>
    </body>
</html>
